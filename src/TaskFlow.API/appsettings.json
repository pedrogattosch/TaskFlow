{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=TaskFlowDb;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "TaskFlow",
    "Audience": "TaskFlow.Api",
    "SecretKey": "REPLACE_WITH_USER_SECRET_OR_ENVIRONMENT_VARIABLE",
    "ExpirationMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Http": {
    "UseHttpsRedirection": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
